{
  "name": "wikistxr",
  "version": "0.1.4",
  "description": "Lightweight wikitext library for syntax highlighting and editing.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*.wasm": "./dist/*.wasm"
  },
  "scripts": {
    "dev": "vite --config vite.config.demo.ts",
    "build:demo": "vite build --config vite.config.demo.ts",
    "build": "bun run build:wasm && bun run build:vite && bun run build:types && bun run copy:wasm",
    "build:wasm": "./build.sh",
    "build:vite": "vite build --config vite.config.ts",
    "build:types": "tsc --project tsconfig.json",
    "copy:wasm": "cp wasm/*.wasm wasm/*.js wasm/*.d.ts dist/ 2>/dev/null || true",
    "format": "prettier --write ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/t7ru/wikistxr.git"
  },
  "keywords": [
    "wikitext",
    "syntax",
    "highlight",
    "wasm",
    "webassembly"
  ],
  "author": "t7ru",
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-top-level-await": "^1.6.0"
  },
  "homepage": "https://wikistxr.t7ru.link"
}
