{
  "name": "wikistxr",
  "version": "0.1.1",
  "description": "Lightweight wikitext library for syntax highlighting and editing.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*.wasm": "./dist/*.wasm"
  },
  "scripts": {
    "dev": "vite --config vite.config.demo.ts",
    "build:wasm": "./build.sh",
    "build": "bun run build:wasm && vite build --config vite.config.ts && tsc --project tsconfig.json && bun run fix-types",
    "build:demo": "vite build --config vite.config.demo.ts",
    "preview": "vite preview --config vite.config.demo.ts",
    "fix-types": "mv dist/src/lib/* dist/ && rm -rf dist/src",
    "format": "prettier . --write",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/t7ru/wikistxr.git"
  },
  "keywords": [
    "wikitext",
    "syntax",
    "highlight",
    "library"
  ],
  "author": "t7ru",
  "license": "MIT",
  "devDependencies": {
    "jsdom": "^27.1.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.0.8",
    "@types/bun": "latest"
  },
  "homepage": "https://wikistxr.t7ru.link",
  "private": true
}
